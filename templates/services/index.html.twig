{% extends 'base.html.twig' %}

{% block title %}{{ 'services.meta_title'|trans }}{% endblock %}
{% block description %}{{ 'services.meta_desc'|trans }}{% endblock %}
{% block og_title %}{{ 'services.og_title'|trans }}{% endblock %}
{% block og_desc %}{{ 'services.og_desc'|trans }}{% endblock %}
{% block og_url %}https://johan-louap.fr/services{% endblock %}
{% block og_image %}https://johan-louap.fr/img/og-services.png{% endblock %}
{% block twitter_image %}https://johan-louap.fr/img/og-services.png{% endblock %}
{% block canonical %}https://johan-louap.fr/services{% endblock %}

{% block jsonld_extra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Boutique e-commerce sur-mesure",
      "description": "Développement de boutiques e-commerce en Symfony 7 ou Shopify, avec paiement sécurisé Stripe et PayPal, catalogue produits, espace client et interface d'administration.",
      "provider": { "@id": "https://johan-louap.fr/#person" },
      "serviceType": "Développement web e-commerce",
      "areaServed": { "@type": "Country", "name": "France" },
      "url": "https://johan-louap.fr/services#ecommerce"
    },
    {
      "@type": "Service",
      "name": "Site vitrine & application web",
      "description": "Création de sites vitrines en Symfony/Twig et d'applications web SPA avec Symfony API et React. SEO optimisé, responsive, déploiement continu.",
      "provider": { "@id": "https://johan-louap.fr/#person" },
      "serviceType": "Développement web",
      "areaServed": { "@type": "Country", "name": "France" },
      "url": "https://johan-louap.fr/services#web"
    },
    {
      "@type": "Service",
      "name": "Application mobile iOS & Android",
      "description": "Développement d'applications mobiles cross-platform avec React Native et Expo, publiées sur l'App Store et Google Play depuis une seule codebase.",
      "provider": { "@id": "https://johan-louap.fr/#person" },
      "serviceType": "Développement mobile",
      "areaServed": { "@type": "Country", "name": "France" },
      "url": "https://johan-louap.fr/services#mobile"
    }
  ]
}
</script>
{% endblock %}

{% block stylesheets %}
<style>
.svc-tooltip {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 2px;
    color: var(--color-accent);
    font-weight: 600;
    cursor: help;
    border-bottom: 1px dashed currentColor;
}
.svc-tooltip::after {
    content: '✦';
    font-size: 0.55rem;
    vertical-align: super;
    opacity: 0.8;
}
.svc-tooltip__box {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 240px;
    padding: 0.6rem 0.85rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.5;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s;
    white-space: normal;
    z-index: 10;
}
.svc-tooltip:hover .svc-tooltip__box { opacity: 1; }

/* Mobile : ancrer le tooltip à la largeur du <li> pour éviter qu'il sorte de l'écran */
@media (max-width: 768px) {
    .svc-checklist li { position: relative; }
    .svc-tooltip { position: static; }
    .svc-tooltip__box {
        left: 0;
        right: 0;
        width: auto;
        max-width: 100%;
        transform: none;
    }
}
</style>
{% endblock %}

{% block body %}
<section class="page-hero">
    <div class="container">
        <span class="section__tag">{{ 'services.hero.tag'|trans }}</span>
        <h1 class="page-hero__title">{{ 'services.hero.title'|trans|raw }}</h1>
        <p class="page-hero__subtitle">
            {{ 'services.hero.subtitle'|trans }}
        </p>
    </div>
</section>

{# ── NAV PRESTATIONS (mobile/tablette) ── #}
<nav class="svc-topnav" id="svcTopnav" aria-label="{{ 'services.hero.tag'|trans }}">
    <a href="#ecommerce" class="svc-topnav__item active" data-svc="ecommerce">{{ 'services.nav.ecommerce'|trans }}</a>
    <a href="#web"       class="svc-topnav__item"        data-svc="web">{{ 'services.nav.web'|trans }}</a>
    <a href="#mobile"    class="svc-topnav__item"        data-svc="mobile">{{ 'services.nav.mobile'|trans }}</a>
</nav>

{# ── NAV PRESTATIONS (desktop sidebar) ── #}
<nav class="svc-sidenav" id="svcSidenav" aria-label="{{ 'services.hero.tag'|trans }}">
    <a href="#ecommerce" class="svc-sidenav__item active" data-svc="ecommerce"><span>🛒</span> {{ 'services.nav.ecommerce'|trans }}</a>
    <a href="#web"       class="svc-sidenav__item"        data-svc="web"><span>🌐</span> {{ 'services.nav.web'|trans }}</a>
    <a href="#mobile"    class="svc-sidenav__item"        data-svc="mobile"><span>📱</span> {{ 'services.nav.mobile'|trans }}</a>
</nav>

{# ── SERVICES ── #}
<section class="section services-detail" id="servicesDetail">
    <div class="container">

        {# E-commerce #}
        <div class="svc-block" id="ecommerce">
            <div class="svc-block__header">
                <div class="svc-block__icon-wrap">🛒</div>
                <div>
                    <span class="section__tag">{{ 'services.ecommerce.label'|trans }}</span>
                    <h2 class="svc-block__title">{{ 'services.ecommerce.title'|trans }}</h2>
                    <p class="svc-block__lead">{{ 'services.ecommerce.lead'|trans }}</p>
                </div>
            </div>
            <div class="svc-block__body">
                <div class="svc-block__features">
                    <h3 class="svc-block__sub">{{ 'services.ecommerce.included'|trans }}</h3>
                    <ul class="svc-checklist">
                        <li>{{ 'services.ecommerce.item.1'|trans }}</li>
                        <li>{{ 'services.ecommerce.item.2'|trans }}</li>
                        <li>
                            <span class="svc-tooltip">Stripe<span class="svc-tooltip__box">{{ 'services.ecommerce.stripe_tooltip'|trans }}</span></span>
                            &amp;
                            <span class="svc-tooltip">PayPal<span class="svc-tooltip__box">{{ 'services.ecommerce.paypal_tooltip'|trans }}</span></span>
                        </li>
                        <li>{{ 'services.ecommerce.item.4'|trans }}</li>
                        <li>{{ 'services.ecommerce.item.5'|trans }}</li>
                        <li>
                            <span class="svc-tooltip">SEO<span class="svc-tooltip__box">{{ 'services.ecommerce.seo_tooltip'|trans }}</span></span>
                            — {{ 'services.ecommerce.item.6'|trans }}
                        </li>
                        <li>{{ 'services.ecommerce.item.7'|trans }}</li>
                        <li>{{ 'services.ecommerce.item.8'|trans }}</li>
                    </ul>
                </div>
                <div class="svc-block__aside">
                    <div class="svc-aside-card">
                        <h4 class="svc-aside-card__title">{{ 'services.ecommerce.custom.title'|trans }}</h4>
                        <p class="svc-aside-card__text">{{ 'services.ecommerce.custom.text'|trans }}</p>
                        <div class="svc-aside-card__tags">
                            <span class="tag" data-tech="symfony">Symfony 7</span>
                            <span class="tag" data-tech="react">React</span>
                            <span class="tag" data-tech="mysql">MySQL</span>
                            <span class="tag" data-tech="api">Stripe / PayPal</span>
                            <span class="tag" data-tech="nginx">Nginx</span>
                        </div>
                    </div>
                    <div class="svc-aside-card">
                        <h4 class="svc-aside-card__title">{{ 'services.ecommerce.shopify.title'|trans }}</h4>
                        <p class="svc-aside-card__text">{{ 'services.ecommerce.shopify.text'|trans }}</p>
                        <div class="svc-aside-card__tags">
                            <span class="tag" data-tech="api">Shopify API</span>
                            <span class="tag" data-tech="api">Shopify Liquid</span>
                            <span class="tag" data-tech="javascript">JavaScript</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="svc-inline-cta">
            <a href="{{ path('app_contact') }}" class="btn btn--outline btn--sm">{{ 'services.ecommerce.cta'|trans }}</a>
        </div>

        <div class="svc-divider"></div>

        {# Site vitrine & web app #}
        <div class="svc-block" id="web">
            <div class="svc-block__header">
                <div class="svc-block__icon-wrap">🌐</div>
                <div>
                    <span class="section__tag">{{ 'services.web.label'|trans }}</span>
                    <h2 class="svc-block__title">{{ 'services.web.title'|trans }}</h2>
                    <p class="svc-block__lead">{{ 'services.web.lead'|trans }}</p>
                </div>
            </div>
            <div class="svc-block__body">
                <div class="svc-block__features">
                    <h3 class="svc-block__sub">{{ 'services.web.included'|trans }}</h3>
                    <ul class="svc-checklist">
                        <li>{{ 'services.web.item.1'|trans }}</li>
                        <li>
                            <span class="svc-tooltip">SEO<span class="svc-tooltip__box">{{ 'services.web.seo_tooltip'|trans }}</span></span>
                            — {{ 'services.web.item.2'|trans }}
                        </li>
                        <li>{{ 'services.web.item.3'|trans }}</li>
                        <li>{{ 'services.web.item.4'|trans }}</li>
                        <li>{{ 'services.web.item.5'|trans }}</li>
                        <li>{{ 'services.web.item.6'|trans }}</li>
                        <li>{{ 'services.web.item.7'|trans }}</li>
                        <li>{{ 'services.web.item.8'|trans }}</li>
                    </ul>
                </div>
                <div class="svc-block__aside">
                    <div class="svc-aside-card">
                        <h4 class="svc-aside-card__title">{{ 'services.web.symfony.title'|trans }}</h4>
                        <p class="svc-aside-card__text">{{ 'services.web.symfony.text'|trans }}</p>
                        <div class="svc-aside-card__tags">
                            <span class="tag" data-tech="symfony">Symfony 7</span>
                            <span class="tag" data-tech="php">Twig</span>
                            <span class="tag" data-tech="mysql">MySQL</span>
                            <span class="tag" data-tech="nginx">Nginx</span>
                        </div>
                    </div>
                    <div class="svc-aside-card">
                        <h4 class="svc-aside-card__title">{{ 'services.web.react.title'|trans }}</h4>
                        <p class="svc-aside-card__text">{{ 'services.web.react.text'|trans }}</p>
                        <div class="svc-aside-card__tags">
                            <span class="tag" data-tech="symfony">Symfony API</span>
                            <span class="tag" data-tech="react">React</span>
                            <span class="tag" data-tech="typescript">TypeScript</span>
                            <span class="tag" data-tech="mysql">MySQL</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="svc-inline-cta">
            <a href="{{ path('app_contact') }}" class="btn btn--outline btn--sm">{{ 'services.web.cta'|trans }}</a>
        </div>

        <div class="svc-divider"></div>

        {# App mobile #}
        <div class="svc-block" id="mobile">
            <div class="svc-block__header">
                <div class="svc-block__icon-wrap">📱</div>
                <div>
                    <span class="section__tag">{{ 'services.mobile.label'|trans }}</span>
                    <h2 class="svc-block__title">{{ 'services.mobile.title'|trans }}</h2>
                    <p class="svc-block__lead">{{ 'services.mobile.lead'|trans }}</p>
                </div>
            </div>
            <div class="svc-block__body">
                <div class="svc-block__features">
                    <h3 class="svc-block__sub">{{ 'services.mobile.included'|trans }}</h3>
                    <ul class="svc-checklist">
                        <li>{{ 'services.mobile.item.1'|trans }}</li>
                        <li>{{ 'services.mobile.item.2'|trans }}</li>
                        <li>{{ 'services.mobile.item.3'|trans }}</li>
                        <li>{{ 'services.mobile.item.4'|trans }}</li>
                        <li>{{ 'services.mobile.item.5'|trans }}</li>
                        <li>{{ 'services.mobile.item.6'|trans }}</li>
                        <li>{{ 'services.mobile.item.7'|trans }}</li>
                    </ul>
                </div>
                <div class="svc-block__aside">
                    <div class="svc-aside-card svc-aside-card--full">
                        <h4 class="svc-aside-card__title">{{ 'services.mobile.rn.title'|trans }}</h4>
                        <p class="svc-aside-card__text">{{ 'services.mobile.rn.text'|trans|raw }}</p>
                        <div class="svc-aside-card__tags">
                            <span class="tag" data-tech="symfony">Symfony API</span>
                            <span class="tag" data-tech="react">React Native</span>
                            <span class="tag" data-tech="typescript">TypeScript</span>
                            <span class="tag" data-tech="react">Expo</span>
                            <span class="tag" data-tech="mysql">MySQL</span>
                            <span class="tag" data-tech="api">Push Notifications</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="svc-inline-cta">
            <a href="{{ path('app_contact') }}" class="btn btn--outline btn--sm">{{ 'services.mobile.cta'|trans }}</a>
        </div>
    </div>
</section>

{# ── PROCESS ── #}
<section class="section section--dark svc-process">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">{{ 'services.process.tag'|trans }}</span>
            <h2 class="section__title">{{ 'services.process.title'|trans }}</h2>
            <p class="section__subtitle">{{ 'services.process.subtitle'|trans }}</p>
        </div>
        <div class="process-grid">
            {% for i in 1..4 %}
            <div class="process-step">
                <div class="process-step__num">{{ ('services.process.step.' ~ i ~ '.num')|trans }}</div>
                <h3 class="process-step__title">{{ ('services.process.step.' ~ i ~ '.title')|trans }}</h3>
                <p class="process-step__text">{{ ('services.process.step.' ~ i ~ '.text')|trans }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── CTA ── #}
<section class="cta-section section">
    <div class="container">
        <div class="cta-box">
            <div class="cta-box__orb"></div>
            <span class="section__tag">{{ 'services.cta.tag'|trans }}</span>
            <h2 class="cta-box__title">{{ 'services.cta.title'|trans }}</h2>
            <p class="cta-box__text">{{ 'services.cta.text'|trans }}</p>
            <a href="{{ path('app_contact') }}" class="btn btn--primary btn--lg">
                {{ 'services.cta.btn'|trans }}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
            </a>
        </div>
    </div>
</section>
{% endblock %}

{% block page_scripts %}
<script src="{{ asset('js/services.js') }}" defer></script>
{% endblock %}
