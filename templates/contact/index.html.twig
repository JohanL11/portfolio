{% extends 'base.html.twig' %}

{% block title %}Contact{% endblock %}
{% block description %}Contactez Johan Louap — Développeur Full Stack Web & Mobile disponible pour CDI, freelance ou collaboration.{% endblock %}
{% block og_title %}Contact — Johan Louap{% endblock %}
{% block og_desc %}Un projet en tête ? Parlons-en — je réponds sous 24h avec une première estimation.{% endblock %}
{% block og_url %}https://johan-louap.fr/contact{% endblock %}
{% block og_image %}https://johan-louap.fr/img/og-contact.png{% endblock %}
{% block twitter_image %}https://johan-louap.fr/img/og-contact.png{% endblock %}

{% block body %}
<section class="page-hero">
    <div class="container">
        <span class="section__tag">Contact</span>
        <h1 class="page-hero__title">Travaillons <span class="text-gradient">ensemble</span></h1>
        <p class="page-hero__subtitle">
            Opportunité, projet, question technique ? Je réponds sous 24h.
        </p>
        <div class="contact-meta">
            <span class="contact-meta__item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Saint-Gratien (95) — Remote possible
            </span>
            <span class="contact-meta__sep">·</span>
            <span class="contact-meta__item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Répond sous 24h
            </span>
            <span class="contact-meta__sep">·</span>
            <span class="contact-meta__item contact-meta__item--avail">
                <span class="contact-meta__dot"></span>
                Disponible
            </span>
        </div>
    </div>
</section>

<section class="section section--contact">
    <div class="container">
        <div class="contact-form-wrap">
            {{ form_start(form, {'attr': {'class': 'contact-form', 'novalidate': 'novalidate'}}) }}
                <div class="form-row">
                    <div class="form-group">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>
                </div>
                <div class="form-group">
                    {{ form_label(form.subject) }}
                    {{ form_widget(form.subject) }}
                    {{ form_errors(form.subject) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.message) }}
                    {{ form_widget(form.message) }}
                    {{ form_errors(form.message) }}
                </div>
                <button type="submit" class="btn btn--primary btn--full">
                    Envoyer le message
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                </button>
            {{ form_end(form) }}

            <div class="contact-footer">
                <a href="mailto:louap.johan@outlook.fr" class="contact-footer__email" id="emailCopyItem" title="Cliquer pour copier">
                    louap.johan@outlook.fr
                    <svg style="opacity:0.4" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    <span id="emailCopyBadge" class="contact-footer__copy-badge">✓ Copié</span>
                </a>
                <span class="contact-footer__sep">·</span>
                <a href="https://github.com/JohanL11" target="_blank" rel="noopener" class="contact-footer__link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    GitHub
                </a>
            </div>
        </div>
    </div>
</section>

{% endblock %}

{% block page_scripts %}
<script src="{{ asset('js/contact.js') }}" defer></script>
{% endblock %}
