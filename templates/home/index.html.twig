{% if featuredProjects|length > 0 %}
<section class="featured-projects section section--dark">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">Réalisations</span>
            <h2 class="section__title">Réalisations mises en avant</h2>
            <p class="section__subtitle">Quelques réalisations représentatives de mon parcours chez Iriga Networks.</p>
        </div>
        <div class="projects-grid">
            {% for project in featuredProjects %}
                <article class="project-card project-card--featured">
                    {% if project.color %}
                    <div class="project-card__cover project-card__cover--{{ project.color }}">
                        {% if project.metrics %}
                        <div class="project-card__metrics">
                            {% for metric in project.metrics %}
                            <div class="project-card__metric">
                                <span class="project-card__metric-value">{{ metric.value }}</span>
                                <span class="project-card__metric-label">{{ metric.label }}</span>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                    {% endif %}
                    <div class="project-card__title-row">
                        <div class="project-card__icon">{{ loop.index == 1 ? '🛠️' : (loop.index == 2 ? '🏢' : '📡') }}</div>
                        <h3 class="project-card__title">{{ project.title }}</h3>
                    </div>
                    <p class="project-card__desc">{{ project.shortDescription }}</p>
                    <div class="project-card__tags">
                        {% for tag in project.tags %}
                            <span class="tag" data-tech="{{ tag|lower|replace({' ': '-', '/': '-', '.': ''}) }}">{{ tag }}</span>
                        {% endfor %}
                    </div>
                </article>
            {% endfor %}
        </div>
        <div class="section__cta">
            <a href="{{ path('app_projects') }}" class="btn btn--primary">
                Voir tous les projets
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
        </div>
    </div>
</section>
{% endif %}

