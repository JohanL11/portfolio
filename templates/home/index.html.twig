{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.home'|trans }}{% endblock %}
{% block description %}{{ app.request.locale == 'en' ? 'Johan Louap — Full Stack Web & Mobile Developer with 7 years of experience. PHP, Zend, React Native, Linux/DevOps.' : 'Johan Louap — Développeur Full Stack Web & Mobile avec 7 ans d\'expérience. PHP, Zend, React Native, Linux/DevOps.' }}{% endblock %}
{% block og_url %}https://johan-louap.fr{% endblock %}
{% block og_image %}https://johan-louap.fr/img/og-default.png{% endblock %}
{% block twitter_image %}https://johan-louap.fr/img/og-default.png{% endblock %}

{% block stylesheets %}
<style>
.hero__typing-line {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--color-accent);
    margin: -0.5rem 0 1.75rem;
    height: 1.4em;
    opacity: 0.85;
}
.hero__typing-prefix { opacity: 0.45; }
.typing-cursor {
    display: inline-block;
    color: var(--color-accent);
    animation: cursorBlink 1s step-end infinite;
    margin-left: 1px;
}
@keyframes cursorBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
</style>
{% endblock %}

{% block body %}
<section class="hero">
    <div class="hero__bg">
        <div class="hero__orb hero__orb--1"></div>
        <div class="hero__orb hero__orb--2"></div>
        <div class="hero__grid"></div>
    </div>
    <div class="hero__container">
        <a href="{{ path('app_contact') }}" class="hero__badge">
            <span class="hero__badge-dot"></span>
            {{ 'hero.badge'|trans }}
        </a>
        <h1 class="hero__title">
            {{ 'hero.greeting'|trans }}<br>
            <span class="hero__title-gradient">Johan Louap</span>
        </h1>
        <p class="hero__typing-line">
            <span class="hero__typing-prefix">// </span><span id="heroTypingText"></span><span class="typing-cursor">|</span>
        </p>
        <p class="hero__subtitle">
            {{ 'hero.subtitle'|trans|raw }}
        </p>
        <div class="hero__actions">
            <a href="{{ path('app_projects') }}" class="btn btn--primary">
                {{ 'hero.btn.projects'|trans }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="{{ path('app_contact') }}" class="btn btn--ghost">{{ 'hero.btn.contact'|trans }}</a>
            <a href="{{ asset('files/cv-johan-louap.pdf') }}" download="CV_Johan_Louap.pdf" class="btn btn--ghost">
                {{ 'hero.btn.cv'|trans }}
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            </a>
        </div>
        <div class="hero__stats">
            <div class="hero__stat">
                <span class="hero__stat-value" data-count="5">5</span>
                <span class="hero__stat-label">{{ 'hero.stat.projects'|trans }}</span>
            </div>
            <div class="hero__stat-divider"></div>
            <div class="hero__stat">
                <span class="hero__stat-value" data-count="23">23</span>
                <span class="hero__stat-label">{{ 'hero.stat.tech'|trans }}</span>
            </div>
            <div class="hero__stat-divider"></div>
            <div class="hero__stat">
                <span class="hero__stat-value" data-count="3">3</span>
                <span class="hero__stat-label">{{ 'hero.stat.mobile'|trans }}</span>
            </div>
        </div>
        <div class="hero__terminal" aria-hidden="true">
            <div class="hero__terminal-bar">
                <span class="hero__terminal-dot" style="background:#ff5f57"></span>
                <span class="hero__terminal-dot" style="background:#ffbd2e"></span>
                <span class="hero__terminal-dot" style="background:#28c840"></span>
                <span class="hero__terminal-title">bash — johan@portfolio:~</span>
            </div>
            <div id="heroTerminal" class="hero__terminal-body"></div>
        </div>
    </div>
    <div class="hero__scroll">
        <div class="hero__scroll-line"></div>
        <span>Scroll</span>
    </div>
</section>

