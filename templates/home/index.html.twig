<section class="security section">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">Sécurité</span>
            <h2 class="section__title">Bonnes pratiques intégrées</h2>
            <p class="section__subtitle">Ce portfolio applique les standards de sécurité web modernes — chaque mesure est vérifiable dans le code source.</p>
        </div>
        <div class="security__grid">
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Protection CSRF</h3>
                    <p class="security-badge__desc">Token Symfony généré et vérifié sur chaque formulaire</p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Validation serveur</h3>
                    <p class="security-badge__desc">Contraintes NotBlank · Length · Email via Symfony Validator</p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Pattern PRG</h3>
                    <p class="security-badge__desc">Post → Redirect → Get, aucun double envoi possible au rechargement</p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Échappement XSS</h3>
                    <p class="security-badge__desc">htmlspecialchars() sur toutes les entrées utilisateur dans les e-mails</p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Injection SQL</h3>
                    <p class="security-badge__desc">Doctrine ORM — requêtes paramétrées, aucun SQL brut</p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Cache & rate limiting</h3>
                    <p class="security-badge__desc">TTL 1 min – 30 j sur l'API Riot Games, protection contre les abus</p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">Secrets hors dépôt</h3>
                    <p class="security-badge__desc">Variables d'environnement, <code>.env</code> protégé par <code>.gitignore</code></p>
                </div>
            </div>
            <div class="security-badge">
                <div class="security-badge__check">✓</div>
                <div class="security-badge__body">
                    <h3 class="security-badge__title">HTTPS / TLS</h3>
                    <p class="security-badge__desc">Certificat SSL, redirection automatique HTTP → HTTPS</p>
                </div>
            </div>
        </div>
    </div>
</section>

