<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-theme="dark">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="app-locale" content="{{ app.request.locale }}">
        <title>{% block title %}Portfolio{% endblock %} — Johan Louap</title>
        <meta name="description" content="{% block description %}Johan Louap — Développeur Full Stack Web & Mobile, 7 ans d'expérience, PHP, React Native, Linux.{% endblock %}">

        {# Open Graph #}
        <meta property="og:type"        content="website">
        <meta property="og:site_name"   content="Johan Louap — Portfolio">
        <meta property="og:title"       content="{% block og_title %}Johan Louap — Développeur Full Stack Web & Mobile{% endblock %}">
        <meta property="og:description" content="{% block og_desc %}7 ans d'expérience en PHP, React Native et Linux/DevOps.{% endblock %}">
        <meta property="og:url"         content="{% block og_url %}https://johan-louap.fr{% endblock %}">
        <meta property="og:image"       content="{% block og_image %}https://johan-louap.fr/img/og-default.png{% endblock %}">
        <meta property="og:image:width"  content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:locale"      content="{{ app.request.locale == 'en' ? 'en_US' : 'fr_FR' }}">

        {# Twitter Card #}
        <meta name="twitter:card"        content="summary_large_image">
        <meta name="twitter:title"       content="{% block twitter_title %}Johan Louap — Développeur Full Stack Web & Mobile{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_desc %}7 ans d'expérience en PHP, React Native et Linux/DevOps.{% endblock %}">
        <meta name="twitter:image"       content="{% block twitter_image %}https://johan-louap.fr/img/og-default.png{% endblock %}">

        <link rel="canonical" href="{% block canonical %}https://johan-louap.fr{% endblock %}">
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">

        {# JSON-LD Schema.org — Person + WebSite (présents sur toutes les pages) #}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "Person",
                    "@id": "https://johan-louap.fr/#person",
                    "name": "Johan Louap",
                    "jobTitle": "Développeur Full Stack Web & Mobile",
                    "url": "https://johan-louap.fr",
                    "image": "https://johan-louap.fr/img/og-default.png",
                    "email": "mailto:louap.johan@outlook.fr",
                    "address": {
                        "@type": "PostalAddress",
                        "addressLocality": "Saint-Gratien",
                        "postalCode": "95210",
                        "addressRegion": "Île-de-France",
                        "addressCountry": "FR"
                    },
                    "sameAs": [
                        "https://github.com/JohanL11"
                    ],
                    "knowsAbout": [
                        "PHP",
                        "Symfony",
                        "React Native",
                        "JavaScript",
                        "API REST",
                        "SQL",
                        "Doctrine ORM",
                        "Linux",
                        "DevOps",
                        "Nginx",
                        "Git"
                    ],
                    "alumniOf": [
                        {
                            "@type": "EducationalOrganization",
                            "name": "ESIEE IT",
                            "address": "Pontoise, France"
                        },
                        {
                            "@type": "EducationalOrganization",
                            "name": "Université de Cergy",
                            "address": "Gennevilliers, France"
                        }
                    ],
                    "nationality": "French"
                },
                {
                    "@type": "WebSite",
                    "@id": "https://johan-louap.fr/#website",
                    "url": "https://johan-louap.fr",
                    "name": "Johan Louap — Portfolio",
                    "description": "Portfolio de Johan Louap, Développeur Full Stack Web & Mobile — PHP, Symfony, React Native, Linux/DevOps.",
                    "inLanguage": "fr-FR",
                    "author": { "@id": "https://johan-louap.fr/#person" },
                    "publisher": { "@id": "https://johan-louap.fr/#person" }
                }
            ]
        }
        </script>
        {% block jsonld_extra %}{% endblock %}

        <script src="{{ asset('js/theme-init.js') }}"></script>
        <link rel="preload" href="{{ asset('fonts/inter-variable.woff2') }}" as="font" type="font/woff2" crossorigin>
        <link rel="preload" href="{{ asset('fonts/jetbrains-mono-variable.woff2') }}" as="font" type="font/woff2" crossorigin>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
    <script>window.APP_LOCALE = '{{ app.request.locale }}';</script>
        <a href="#main-content" class="skip-link">{{ 'skip_to_content'|trans }}</a>
        <nav class="navbar" id="navbar">
            <div class="navbar__container">
                <a href="{{ path('app_home') }}" class="navbar__logo" aria-label="Johan Louap — Accueil">
                    <svg class="navbar__logo-svg" width="36" height="36" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="jl-g" x1="8" y1="8" x2="54" y2="52" gradientUnits="userSpaceOnUse">
                                <stop offset="0%" stop-color="#c7d2fe"/>
                                <stop offset="100%" stop-color="#7c3aed"/>
                            </linearGradient>
                        </defs>
                        <g class="logo-j">
                            <path d="M 10 8 L 32 8 L 32 43 Q 32 52 16 52" stroke="url(#jl-g)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </g>
                        <g class="logo-l">
                            <path d="M 32 8 L 32 52 L 52 52" stroke="url(#jl-g)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </g>
                    </svg>
                </a>
                <button class="navbar__toggle" id="navToggle" aria-label="{{ 'nav.aria_menu'|trans }}" aria-expanded="false" aria-controls="navLinks">
                    <span></span><span></span><span></span>
                </button>
                <ul class="navbar__links" id="navLinks">
                    <li><a href="{{ path('app_home') }}" class="navbar__link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">{{ 'nav.home'|trans }}</a></li>
                    <li><a href="{{ path('app_projects') }}" class="navbar__link {% if app.request.attributes.get('_route') == 'app_projects' %}active{% endif %}">{{ 'nav.projects'|trans }}</a></li>
                    <li><a href="{{ path('app_services') }}" class="navbar__link {% if app.request.attributes.get('_route') == 'app_services' %}active{% endif %}">{{ 'nav.services'|trans }}</a></li>
                    <li><a href="{{ path('app_league') }}" class="navbar__link navbar__link--lol {% if app.request.attributes.get('_route') == 'app_league' %}active{% endif %}">{{ 'nav.league'|trans }}</a></li>
                    <li><a href="{{ path('app_contact') }}" class="navbar__link navbar__link--cta {% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}">{{ 'nav.contact'|trans }}</a></li>
                    <li class="navbar__mobile-controls">
                        <a href="{{ path('app_locale', {locale: app.request.locale == 'fr' ? 'en' : 'fr'}) }}"
                           class="lang-toggle"
                           title="{{ app.request.locale == 'fr' ? 'Switch to English' : 'Passer en français' }}">
                            {{ 'nav.lang'|trans }}
                        </a>
                        <button class="theme-toggle" id="themeToggle" aria-label="{{ 'nav.aria_theme'|trans }}" title="{{ 'nav.title_theme'|trans }}">
                            <svg id="themeIconMoon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
                            <svg id="themeIconSun"  width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                        </button>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="main-content" id="main-content" tabindex="-1">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash--{{ label }}">
                        <span class="flash__icon">{% if label == 'success' %}✓{% else %}✕{% endif %}</span>
                        {{ message|trans }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <button class="back-to-top" id="backToTop" aria-label="{{ 'back_to_top'|trans }}" title="{{ 'back_to_top'|trans }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 15l-6-6-6 6"/></svg>
        </button>

        <footer class="footer">
            <div class="footer__container">
                <div class="footer__brand">
                    <svg width="22" height="22" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <defs>
                            <linearGradient id="jl-footer-g" x1="10" y1="8" x2="52" y2="52" gradientUnits="userSpaceOnUse">
                                <stop offset="0%" stop-color="#c7d2fe"/>
                                <stop offset="100%" stop-color="#7c3aed"/>
                            </linearGradient>
                        </defs>
                        <path d="M 10 8 L 32 8 L 32 43 Q 32 52 16 52" stroke="url(#jl-footer-g)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M 32 8 L 32 52 L 52 52" stroke="url(#jl-footer-g)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Portfolio</span>
                </div>
                <p class="footer__tagline">{{ 'footer.tagline'|trans }}</p>
                <div class="footer__links">
                    <a href="https://github.com/JohanL11" target="_blank" rel="noopener" class="footer__link">GitHub</a>
                    <a href="{{ path('app_contact') }}" class="footer__link">{{ 'nav.contact'|trans }}</a>
                    <a href="{{ path('app_legal_notice') }}" class="footer__link">{{ 'footer.legal'|trans }}</a>
                    <a href="{{ path('app_privacy_policy') }}" class="footer__link">{{ 'footer.privacy'|trans }}</a>
                </div>
                <p class="footer__copy">© {{ "now"|date("Y") }} Johan Louap — {{ 'footer.made_with'|trans }}</p>
            </div>
        </footer>
        <script src="{{ asset('js/base.js') }}" defer></script>
        {% block page_scripts %}{% endblock %}
    </body>
</html>
